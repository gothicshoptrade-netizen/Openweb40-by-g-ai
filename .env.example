# GEMINI_API_KEY: Required for Gemini AI API calls.
# For static deployment (Vite), use VITE_GEMINI_API_KEY
VITE_GEMINI_API_KEY="YOUR_GEMINI_API_KEY"
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# OPENROUTER_API_KEY: Required for OpenRouter AI API calls.
# Users configure this via the Secrets panel in the AI Studio UI.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# TELEGRAM_BOT_TOKEN: Required for sending form submissions to Telegram.
TELEGRAM_BOT_TOKEN="MY_TELEGRAM_BOT_TOKEN"

# TELEGRAM_CHAT_ID: The Telegram chat ID (e.g. @krisdev_13 or numeric ID) to send messages to.
TELEGRAM_CHAT_ID="MY_TELEGRAM_CHAT_ID"
